# =============================================
# Environment Variables — Copy to .env and fill in your values.
# This file is safe to commit. NEVER commit the actual .env file.
# =============================================

# ---- SERVER ----
PORT=5000

# ---- FRONTEND URL (CORS) ----
# Must match exactly — no trailing slash.
# For local dev:
FRONTEND_URL=http://localhost:5173
# For production (Netlify):
# FRONTEND_URL=https://your-netlify-app.netlify.app

# ---- MONGODB ----
# For local MongoDB:
MONGO_URI=mongodb://localhost:27017/attendance_db
# For MongoDB Atlas (production):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/attendance_db?retryWrites=true&w=majority

# ---- JWT SECRETS ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# MUST be different from each other. NEVER use the example values in production.
JWT_SECRET=CHANGE_ME_use_64_random_chars
REFRESH_SECRET=CHANGE_ME_use_different_64_random_chars

# ---- DEFAULT ADMIN ----
# Used only on first startup when no admin account exists yet.
ADMIN_DEFAULT_EMAIL=admin@yourdomain.com
ADMIN_DEFAULT_PASSWORD=ChangeMe@2024!

# ---- GEOFENCE SETTINGS ----
# Latitude & longitude of the office/approved attendance location.
GEOFENCE_LAT=10.786760
GEOFENCE_LNG=78.689341

# Allowed radius in meters around the geofence centre.
GEOFENCE_RADIUS=100

# Maximum acceptable GPS accuracy (in metres). Readings less accurate than this are rejected.
MAX_LOCATION_ACCURACY_METERS=200

# Maximum age of the GPS fix (in milliseconds). Stale fixes are rejected.
MAX_LOCATION_AGE_MS=120000

# ---- BACKEND PUBLIC URL ----
# The publicly-accessible URL of this backend — no trailing slash.
# Used to build absolute URLs for profile images returned in API responses.
# For local dev:
BACKEND_URL=http://localhost:5000
# For Render production:
# BACKEND_URL=https://your-backend-name.onrender.com
